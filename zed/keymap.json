[
  {
    "context": "ProjectPanel || (Editor && vim_mode == normal || vim_mode == visual) && (!VimWaiting && !menu && !AgentPanel && !BufferSearchBar && !ProjectSearchBar)",
    "bindings": {
      "space \\": "project_panel::Toggle",
      "space a a": "agent::Toggle",
      "space f": "file_finder::Toggle",
      "space g b": "git::Switch",
      "space g c": "git::GenerateCommitMessage",
      "space g r": "git::Restore",
      "space g R": "git::RestoreFile",
      "space g S": "git::StageFile",
      "space g s": "git::ToggleStaged",
      "space n": "editor::ToggleLineNumbers",
      "space p": "projects::OpenRecent",
      "space s s": "outline::Toggle",
      "space space": "pane::AlternateFile",
      "space w": "workspace::Save",
      "] g": "editor::GoToHunk",
      "[ g": "editor::GoToPreviousHunk",
      "] b": "pane::ActivateNextItem",
      "[ b": "pane::ActivatePreviousItem",
    },
  },
  {
    "context": "Editor && vim_mode != insert && (!VimWaiting && !menu && !AgentPanel && !BufferSearchBar && !ProjectSearchBar)",
    "bindings": {
      "g i": "editor::GoToImplementation",
      "g r a": "editor::ToggleCodeActions",
      "g r n": "editor::Rename",
      ", a": "editor::SelectAll",
      ", m": "markdown::OpenFollowingPreview",
      ", r": "buffer_search::Deploy",
    },
  },
  {
    "context": "Editor && vim_mode == visual && (!VimWaiting && !menu && !AgentPanel && !BufferSearchBar && !ProjectSearchBar)",
    "bindings": {
      ", S": "editor::SortLinesCaseInsensitive",
      "n": "editor::SelectNext",
      "q": "editor::FindNextMatch",
      "alt-down": "editor::MoveLineDown",
      "alt-up": "editor::MoveLineUp",
      "j": "editor::MoveLineDown",
      "k": "editor::MoveLineUp",
    },
  },
  {
    "context": "Editor && vim_mode == normal && (!VimWaiting && !menu && !AgentPanel && !BufferSearchBar && !ProjectSearchBar)",
    "bindings": {
      "alt-down": "editor::MoveLineDown",
      "alt-up": "editor::MoveLineUp",
      "w down": "workspace::ActivatePaneDown",
      "w left": "workspace::ActivatePaneLeft",
      "w right": "workspace::ActivatePaneRight",
      "w up": "workspace::ActivatePaneUp",
      "w h": "workspace::ActivatePaneLeft",
      "w j": "workspace::ActivatePaneDown",
      "w k": "workspace::ActivatePaneUp",
      "w l": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "Dock || AgentPanel",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      ", w o": "workspace::CloseInactiveTabsAndPanes",
      ", d": "workspace::NewTerminal",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "cmd-r": "project_panel::Rename",
      "cmd-a": "project_panel::NewFile",
      "cmd-c": "project_panel::Copy",
      "cmd-p": "project_panel::Paste",
      "cmd-d": "project_panel::Delete",
      "cmd-x": "project_panel::Cut",
    },
  },
  {
    "context": "Editor || Terminal",
    "bindings": {
      "cmd-]": "pane::ActivateNextItem",
      "cmd-[": "pane::ActivatePreviousItem",
      "cmd-shift-enter": "workspace::ToggleZoom",
      "ctrl-w k": "workspace::SwapPaneUp",
      "ctrl-w j": "workspace::SwapPaneDown",
      "ctrl-w h": "workspace::SwapPaneLeft",
      "ctrl-w l": "workspace::SwapPaneRight",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "escape escape": "agent::Toggle",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-d": "workspace::NewTerminal",
      "escape escape": "workspace::ToggleZoom",
      "ctrl-w up": "terminal_panel::Toggle",
    },
  },
  {
    "bindings": {
      "alt-cmd-i": "dev::OpenHighlightsTreeView",
    },
  },
]
