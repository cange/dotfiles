// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "terminal": {
    "scroll_multiplier": 1.0,
    "scrollbar": {
      "show": "system",
    },
    "alternate_scroll": "on",
  },
  "use_system_prompts": true,
  "colorize_brackets": true,
  "redact_private_values": false,
  "use_system_path_prompts": true,
  "cursor_blink": true,
  "hard_tabs": false,
  "semantic_tokens": "off",
  "toolbar": {
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "title_bar": {
    "show_branch_status_icon": false,
  },
  "status_bar": {
    "show_active_file": true,
    "line_endings_button": false,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "tab_size": 2,
  "buffer_line_height": {
    "custom": 1.3,
  },
  "language_models": {
    "lmstudio": {
      "api_url": "http://127.0.0.1:1234/v1",
    },
    "opencode": {
      "show_zen_models": true,
      "show_free_models": true,
      "show_go_models": true,
    },
  },
  "languages": {
    "Lua": {
      "auto_indent": "syntax_aware",
    },
  },
  "theme": "Terafox - blurred (dev)",
  "icon_theme": "Material Icon Theme",

  // Agents
  "agent": {
    "dock": "left",
    "enable_feedback": true,
    "default_profile": "ask",
    "inline_assistant_model": {
      "provider": "lmstudio",
      "model": "gemma-4-e4b",
      "enable_thinking": false,
    },

    "favorite_models": [
      {
        "provider": "lmstudio",
        "model": "gemma-4-26b-a4b-qat",
        "enable_thinking": true,
      },
      {
        "provider": "lmstudio",
        "model": "gemma-4-e4b",
        "enable_thinking": true,
      },
    ],
    "default_model": {
      "provider": "lmstudio",
      "model": "gemma-4-26b-a4b-qat",
      "enable_thinking": false,
    },

  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "open_ai_compatible_api",
    "open_ai_compatible_api": {
      "prompt_format": "code_gemma",
      "max_output_tokens": 164,
      "model": "gemma-4-e4b",
      "api_url": "http://localhost:1234/v1/completions",
    },
  },

  "vim_mode": true,
  "vim": {
    "highlight_on_yank_duration": 200,
    "use_smartcase_find": true,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "location": "status_bar",
    },
  },

  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "$CONTEXT7_LICENSE_KEY",
      },
    },
    "mcp-server-github": {
      "enabled": true,
      "settings": {
        "github_personal_access_token": "$GITHUB_TOKEN",
      },
    },
  },

  "indent_guides": {
    "coloring": "indent_aware",
  },
  "telemetry": { "metrics": false },

  "ensure_final_newline_on_save": true,
  "current_line_highlight": "line",
  "lsp_document_colors": "background",

  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 13,
  "buffer_font_weight": 300,
  "ui_font_family": ".ZedSans",
  "ui_font_size": 15,
  "ui_font_weight": 400,

  // Character counts at which to show wrap guides in the editor.
  "wrap_guides": [80, 120],

  // The number of lines to keep above/below the cursor when scrolling.
  "vertical_scroll_margin": 8,
  "scrollbar": { "show": "auto" },
  "collaboration_panel": { "dock": "right", "button": false },
  "git_panel": { "group_by": "status",
                 "dock": "right", "tree_view": false },
}
